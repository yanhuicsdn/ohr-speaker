#!/bin/bash
# batch-transcribe — transcribe all audio files in a directory
#
# Usage:  batch-transcribe recordings/           # transcribe all audio files
#         batch-transcribe recordings/ -o srt     # generate SRT for each
#         batch-transcribe recordings/ --parallel  # transcribe in parallel
#
# Requires: ohr installed

FORMAT="plain"
LANGUAGE=""
PARALLEL=false
EXT_FILTER=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -o|--output)   FORMAT="$2"; shift 2 ;;
        -l|--language) LANGUAGE="$2"; shift 2 ;;
        -p|--parallel) PARALLEL=true; shift ;;
        -e|--ext)      EXT_FILTER="$2"; shift 2 ;;
        -h|--help)
            echo "batch-transcribe — transcribe all audio files in a directory"
            echo ""
            echo "Usage: batch-transcribe [OPTIONS] <directory>"
            echo ""
            echo "  -o, --output <fmt>   plain (default), json, srt, vtt"
            echo "  -l, --language <code> Language code"
            echo "  -e, --ext <ext>       Filter by extension (e.g. m4a)"
            echo "  -p, --parallel        Process files in parallel"
            echo "  -h, --help            Show this help"
            echo ""
            echo "Examples:"
            echo "  batch-transcribe recordings/"
            echo "  batch-transcribe ~/meetings/ -o srt"
            echo "  batch-transcribe podcasts/ -e mp3 -o vtt"
            echo "  batch-transcribe interviews/ --parallel"
            echo ""
            echo "Output files are saved next to source: file.m4a → file.txt (or .srt/.vtt/.json)"
            echo ""
            echo "Requires: ohr (speech-to-text)"
            exit 0
            ;;
        -*) echo "Unknown option: $1. Use --help."; exit 1 ;;
        *)  DIR="$1"; shift ;;
    esac
done

if [[ -z "$DIR" ]]; then echo "Usage: batch-transcribe <directory>"; exit 1; fi
if [[ ! -d "$DIR" ]]; then echo "Error: not a directory: $DIR" >&2; exit 1; fi

if ! command -v ohr &>/dev/null; then
    echo "Error: ohr not found" >&2; exit 1
fi

# Map output format to file extension
case "$FORMAT" in
    plain) OUT_EXT="txt" ;;
    json)  OUT_EXT="json" ;;
    srt)   OUT_EXT="srt" ;;
    vtt)   OUT_EXT="vtt" ;;
    *)     echo "Unknown format: $FORMAT"; exit 1 ;;
esac

# Find audio files
AUDIO_EXTS="m4a wav mp3 mp4 caf aiff aif flac"
FIND_ARGS=()
if [[ -n "$EXT_FILTER" ]]; then
    FIND_ARGS=(-name "*.${EXT_FILTER}")
else
    first=true
    for ext in $AUDIO_EXTS; do
        if $first; then
            FIND_ARGS+=(-name "*.${ext}")
            first=false
        else
            FIND_ARGS+=(-o -name "*.${ext}")
        fi
    done
    FIND_ARGS=("(" "${FIND_ARGS[@]}" ")")
fi

FILES=$(find "$DIR" -maxdepth 1 -type f "${FIND_ARGS[@]}" | sort)
COUNT=$(echo "$FILES" | grep -c .)

if [[ $COUNT -eq 0 ]]; then
    echo "No audio files found in $DIR"
    exit 0
fi

echo -e "\033[36mBatch transcribing $COUNT files → .$OUT_EXT\033[0m" >&2

LANG_FLAG=""
[[ -n "$LANGUAGE" ]] && LANG_FLAG="-l $LANGUAGE"

SUCCESS=0
FAIL=0

transcribe_one() {
    local file="$1"
    local base="${file%.*}"
    local outfile="${base}.${OUT_EXT}"
    local name=$(basename "$file")

    ohr -o "$FORMAT" $LANG_FLAG "$file" > "$outfile" 2>/dev/null
    if [[ $? -eq 0 ]]; then
        echo -e "  \033[32m✓\033[0m $name → $(basename "$outfile")"
        return 0
    else
        echo -e "  \033[31m✗\033[0m $name (failed)"
        rm -f "$outfile"
        return 1
    fi
}

if $PARALLEL; then
    export -f transcribe_one
    export FORMAT OUT_EXT LANG_FLAG
    echo "$FILES" | xargs -P 4 -I {} bash -c 'transcribe_one "$@"' _ {}
else
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        if transcribe_one "$file"; then
            SUCCESS=$((SUCCESS + 1))
        else
            FAIL=$((FAIL + 1))
        fi
    done <<< "$FILES"
fi

echo ""
echo -e "\033[36mDone:\033[0m $SUCCESS succeeded, $FAIL failed"
