#!/bin/bash
# voice-search — search inside audio files by spoken content
#
# Usage:  voice-search "budget" meeting.m4a           # find "budget" mentions
#         voice-search "action items" *.m4a            # search multiple files
#         voice-search -i "error" recording.wav        # case-insensitive
#
# Requires: ohr installed

CASE_INSENSITIVE=false
POSITIONAL=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i|--ignore-case) CASE_INSENSITIVE=true; shift ;;
        -h|--help)
            echo "voice-search — search inside audio files by spoken content"
            echo ""
            echo "Usage: voice-search [OPTIONS] <pattern> <file>..."
            echo ""
            echo "  -i, --ignore-case  Case-insensitive matching"
            echo "  -h, --help         Show this help"
            echo ""
            echo "Examples:"
            echo "  voice-search \"budget\" meeting.m4a"
            echo "  voice-search \"action items\" *.m4a"
            echo "  voice-search -i \"error\" logs/*.wav"
            echo ""
            echo "Requires: ohr (speech-to-text)"
            exit 0
            ;;
        -*) echo "Unknown option: $1. Use --help."; exit 1 ;;
        *)  POSITIONAL+=("$1"); shift ;;
    esac
done

PATTERN="${POSITIONAL[0]}"
if [[ -z "$PATTERN" || ${#POSITIONAL[@]} -lt 2 ]]; then
    echo "Usage: voice-search <pattern> <file>..."
    exit 1
fi

if ! command -v ohr &>/dev/null; then
    echo "Error: ohr not found" >&2; exit 1
fi

GREP_FLAGS=""
$CASE_INSENSITIVE && GREP_FLAGS="-i"

FOUND=0

for FILE in "${POSITIONAL[@]:1}"; do
    if [[ ! -f "$FILE" ]]; then
        echo -e "\033[33mskip:\033[0m $FILE (not found)" >&2
        continue
    fi

    # Transcribe with timestamps
    result=$(ohr --timestamps "$FILE" 2>/dev/null)
    if [[ $? -ne 0 ]]; then
        echo -e "\033[33mskip:\033[0m $FILE (transcription failed)" >&2
        continue
    fi

    # Search for pattern in transcript
    matches=$(echo "$result" | grep $GREP_FLAGS "$PATTERN")
    if [[ -n "$matches" ]]; then
        FOUND=$((FOUND + 1))
        echo -e "\033[36m$(basename "$FILE"):\033[0m"
        echo "$matches" | while IFS= read -r line; do
            # Highlight the match
            if $CASE_INSENSITIVE; then
                highlighted=$(echo "$line" | sed -E "s/($PATTERN)/$(printf '\033[1;33m')\\1$(printf '\033[0m')/gi")
            else
                highlighted=$(echo "$line" | sed -E "s/($PATTERN)/$(printf '\033[1;33m')\\1$(printf '\033[0m')/g")
            fi
            echo "  $highlighted"
        done
        echo ""
    fi
done

if [[ $FOUND -eq 0 ]]; then
    echo "No matches for \"$PATTERN\"" >&2
    exit 1
fi
